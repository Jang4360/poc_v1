# Copy this file to `.env` for local/dev use.
# Do not commit real secrets.

# Core database settings
POSTGRES_HOST=localhost
POSTGRES_HOST_PORT=15432
POSTGRES_DB=ieumgil
POSTGRES_USER=ieumgil
POSTGRES_PASSWORD=change-me

# Host ports exposed by docker compose
BACKEND_HOST_PORT=18080
GRAPHHOPPER_HOST_PORT=18989

# Backend direct-run defaults
# docker compose overrides these inside the backend container.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15432/ieumgil
SPRING_DATASOURCE_USERNAME=ieumgil
SPRING_DATASOURCE_PASSWORD=change-me
GRAPHHOPPER_BASE_URL=http://localhost:18989

# ETL preview helpers
KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key

# Optional external APIs for current and follow-up workstreams
ODSAY_API_BASE_URL=https://api.odsay.com/v1/api
ODSAY_API_KEY=
ODSAY_SERVER_IP=

BUSAN_BIMS_API_BASE_URL=https://apis.data.go.kr/6260000/BusanBIMS
BUSAN_BIMS_SERVICE_KEY_ENCODING=
BUSAN_BIMS_SERVICE_KEY_DECODING=

BUSAN_ACSTC_BCN_API_BASE_URL=https://apis.data.go.kr/6260000/BusanAcstcBcnInfoService
BUSAN_ACSTC_BCN_SERVICE_KEY_DECODING=

BUSAN_SUBWAY_OPERATION_DATASET_ID=15082980
BUSAN_SUBWAY_OPERATION_PORTAL_URL=https://www.data.go.kr/data/15082980/fileData.do
BUSAN_SUBWAY_OPERATION_SWAGGER_URL=https://infuser.odcloud.kr/oas/docs?namespace=15082980/v1
BUSAN_SUBWAY_OPERATION_API_BASE_URL=https://api.odcloud.kr/api
BUSAN_SUBWAY_OPERATION_API_PATH=/15082980/v1/uddi:e9c28907-a511-428d-b5ec-e1c6c988396a
BUSAN_SUBWAY_OPERATION_SERVICE_KEY_ENCODING=
BUSAN_SUBWAY_OPERATION_SERVICE_KEY_DECODING=

# Planned auth workstream
JWT_ISSUER_URI=
